# Copy this file to ".env" and fill in the values from Google Cloud Console.
# See SETUP.md for step-by-step instructions.

# From Google Cloud Console > APIs & Services > Credentials > OAuth client (Web application)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must EXACTLY match an Authorized redirect URI in the Google OAuth client.
# Local dev:
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Production example:
# GOOGLE_REDIRECT_URI=https://dashboard.feelgoodchiro.com/auth/google/callback

# Any long random string — used to sign the login session cookie.
SESSION_SECRET=change-me-to-a-long-random-string

PORT=3000
